{
    "schema_version": 1,
    "categories": [
        {
            "category": "Official",
            "color": "#c8a96e",
            "rules": [
                { "field": "channelId", "type": "exact", "patterns": ["UCJToUvYrmkmTCR-bluEaQfA","UCM35rMMfPj1wj1nwe-DxSAg","UCHNhsC0VPItCMeAl11T3rAQ"] },
                { "field": "channel",   "type": "regex", "patterns": ["BAND-MAID"] }
            ],
            "notes": "Official BAND-MAID YouTube channel"
        },
        {
            "category": "Reaction",
            "color": "#a8c4a0",
            "rules": [
                { "field": "channelId", "type": "exact", "patterns": [
                    "UCvKUIZjMmlHJ9vjGJey0SBQ",
                    "UCXj2vn4DScTLfa2Dtw3f5HA",
                    "UCR41xBLK6sk-1tItQmS2KWQ",
                    "UCYok5F7c2kHJP36zH9GgEng",
                    "UCsBwg8OaxXyRb5UbpgsIiCg",
                    "UCbwRrjUM3xncEAglgY-EHAw",
                    "UC-WWqxF7LPOssDbasMJyOJg",
                    "UCElNNUiBC67ypav4q267isA",
                    "UCMNI9VvZu0zy4xICGjBJAGQ"
                  ] 
                },
                { "field": "channel", "type": "regex", "patterns": [
                    "react",
                    "REACCIÓN"
                  ]
                },
                { "field": "title", "type": "regex", "patterns": [
                    "\\breact\\w*\\b",
                    "\\bhear\\w*\\b",
                    "\\blisten\\w*\\b",
                    "react",
                    "REACCIÓN",
                    "Review"
                  ]
                }
            ],
            "notes": "Matches react/reacts/reacting/reaction/reactions, hear/hears/hearing/heard, listen/listens/listening/listened"
        },
        {
            "category": "Cover",
            "color": "#c4a484",
            "rules": [
                { "field": "channelId", "type": "exact", "patterns": [
                    "UCOi-oaygEodP5SpzX7sw3nQ"
                  ] 
                },
               { "field": "title", "type": "regex", "patterns": [
                    "\\bcover\\w*\\b",
                    "\\bdrum\\s*cam\\b",
                    "(guitar|bass|drum|vocal)\\s+cover\\b",
                    "MIDI",
                    "drumcover",
                    "歌ってみた",
                    "弾いてみた",
                    "叩いてみた"
                ]}
            ],
            "notes": "Includes Japanese cover terms: utattemita (sang), hiitemita (played), tataitemita (drummed)"
        },
        {
            "category": "Tab/Score",
            "color": "#a89cc4",
            "rules": [
                { "field": "channelId", "type": "exact", "patterns": [
                    "UCJgjHK1zDcpm0hiSpMqkPGw"
                  ] 
                },
               { "field": "title", "type": "regex", "patterns": [
                    "\\bTab\\w*\\b",
                    "\\bsheet\\s*music\\b"
                ]}
            ],
            "notes": "Includes Japanese cover terms: utattemita (sang), hiitemita (played), tataitemita (drummed)"
        },
        {
            "category": "News",
            "color": "#d06560",
            "rules": [
                { "field": "channel", "type": "regex", "patterns": [
                    "\\bnews\\w*\\b"
                  ] 
                },
                { "field": "title", "type": "regex", "patterns": [
                    "\\bnews\\w*\\b"
                  ]
                }
            ],
            "notes": "Matches react/reacts/reacting/reaction/reactions, hear/hears/hearing/heard, listen/listens/listening/listened"
        },
        {
            "category": "Isolated Tracks",
            "color": "#8ab098",
            "rules": [
                { "field": "channelId", "type": "exact", "patterns": [
                    "UC2HQH01Et8x48Mb4MWap2Hg",
                    "UCYZ1ZZi0kyL6nggbaVZEQKQ",
                    "UC2bYqm4ctyvZPRzapqHy9lg"
                  ] 
                },
               { "field": "title", "type": "regex", "patterns": [
                    "isolated",
                    "\\bbacking\\s*track\\b"
                  ]
               }
            ],
            "notes": "Includes Japanese cover terms: utattemita (sang), hiitemita (played), tataitemita (drummed)"
        },
        {
            "category": "Live Report",
            "color": "#9cb4d4",
            "rules": [
                { "field": "title", "type": "regex", "patterns": [
                    "\\blive\\s*report\\b",
                    "\\bconcert\\s*report\\b",
                    "\\bshow\\s*report\\b",
                    "Impression",
                    "(?i)\\bokyu-?ji\\b",
                    "recap"
                ]}
            ]
        },
        {
            "category": "Interview",
            "color": "#b4a4c4",
            "rules": [
                { "field": "title", "type": "regex", "patterns": [
                    "\\binterview\\b",
                    "\\bsit[-\\s]down\\b",
                    "\\btalks?\\s+with\\b",
                    "\\bQ\\s*&\\s*A\\b"
                ]}
            ]
        },
        {
            "category": "Unboxing",
            "color": "#a4b4c4",
            "rules": [
                { "field": "title", "type": "regex", "patterns": [
                    "\\bunbox\\w*\\b"
                ]}
            ]
        },
        {
            "category": "Podcast",
            "color": "#8a3a3a",
            "rules": [
                { "field": "channelId", "type": "exact", "patterns": [
                    "UCoGH2sqzaxLjcWpkzn83cZg"
                  ] 
                },
                { "field": "title", "type": "regex", "patterns": [
                    "podcast"
                ]}
            ]
        },
        {
            "category": "Fan Art",
            "color": "#d4b89c",
            "rules": [
                { "field": "title", "type": "regex", "patterns": [
                    "\\bdraw\\w*\\b",
                    "\\bpaint\\w*\\b"
                ]}
            ]
        },
        {
            "category": "Live",
            "color": "#7ba87a",
            "rules": [
                { "field": "title", "type": "regex", "patterns": [
                    "session"
                ]}
            ]
        },
        {
            "category": "Lyric Video",
            "color": "#9cb4d4",
            "rules": [
                { "field": "title", "type": "regex", "patterns": [
                    "Legendado"
                ]}
            ]
        }        
    ],
    "default_category": {
        "category": "MISC",
        "color": "#666666"
    }
}
